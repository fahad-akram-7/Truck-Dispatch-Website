generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DRIVER
  CUSTOMER
}

enum RequestStatus {
  PENDING
  QUOTED
  ASSIGNED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  passwordHash String
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  driver        Driver?
  assignedLoads Dispatch[] @relation("AssignedByAdmin")
  statusUpdates StatusLog[] @relation("StatusUpdatedBy")
}

model Driver {
  id            String   @id @default(cuid())
  userId        String   @unique
  licenseNo     String   @unique
  phone         String
  availability  String   @default("AVAILABLE")
  currentCity   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  dispatches Dispatch[]
}

model LoadRequest {
  id            String        @id @default(cuid())
  customerName  String
  customerEmail String
  origin        String
  destination   String
  weightKg      Float
  distanceKm    Float
  priority      String        @default("STANDARD")
  requestedDate DateTime
  status        RequestStatus @default(PENDING)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  quote     Quote?
  dispatch  Dispatch?
}

model Quote {
  id             String   @id @default(cuid())
  loadRequestId  String   @unique
  baseCost       Float
  fuelSurcharge  Float
  weightCharge   Float
  priorityCharge Float
  totalAmount    Float
  validUntil     DateTime
  createdAt      DateTime @default(now())

  loadRequest LoadRequest @relation(fields: [loadRequestId], references: [id], onDelete: Cascade)
}

model Dispatch {
  id            String        @id @default(cuid())
  loadRequestId String        @unique
  driverId      String
  assignedById  String
  assignedAt    DateTime      @default(now())
  currentStatus RequestStatus @default(ASSIGNED)
  etaDate       DateTime?

  loadRequest LoadRequest @relation(fields: [loadRequestId], references: [id], onDelete: Cascade)
  driver      Driver      @relation(fields: [driverId], references: [id], onDelete: Restrict)
  assignedBy  User        @relation("AssignedByAdmin", fields: [assignedById], references: [id], onDelete: Restrict)
  logs        StatusLog[]
}

model StatusLog {
  id          String        @id @default(cuid())
  dispatchId  String
  status      RequestStatus
  note        String?
  updatedById String
  timestamp   DateTime      @default(now())

  dispatch  Dispatch @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  updatedBy User     @relation("StatusUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
}
